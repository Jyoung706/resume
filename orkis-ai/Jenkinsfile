pipeline {
    agent { label 'jenkins-build-agent'}

    environment {
      GITLAB_REGISTRY = 'gitlab-registry.orkis.kr'

      KUBE_NAMESPACE = 'orkis'
      APP_NAME = 'orkis-ai'

      PROJECT_PATH = 'rnd/ai'
      IMAGE_NAME = "${GITLAB_REGISTRY}/${PROJECT_PATH}/${APP_NAME}"
    }

    stages {
        stage('Docker Image Build and Push') {
        steps {
          script {
            dockerBuildAndPush()
          }
        }
      }

      stage('Deploy to K8s') {
        steps {
          script {
            deployToKubernetes()
          }
        }
      }
    }

    post {
        always {
            echo "Pipeline Completed"
        }
        success {
            echo "Pipeline Succeeded"
        }
        failure {
            echo "Pipeline Failed"
        }
    }
}

def deployToKubernetes() {
  container('kubectl') {
    deployApplication()
  }
}

def dockerBuildAndPush() {
  script {
    try {
      container('docker') {
        withCredentials([
          usernamePassword(
            credentialsId: 'bi-gitlab-admin-accesstoken',
            usernameVariable: 'REGISTRY_USER',
            passwordVariable: 'REGISTRY_PASSWORD'
          )
        ]) {
          sh """
              # Docker 로그인
              echo \${REGISTRY_PASSWORD} | docker login -u \${REGISTRY_USER} --password-stdin \${GITLAB_REGISTRY}
              
              # 이미지 빌드
              docker build -f prod.Dockerfile -t \${IMAGE_NAME}:\${BUILD_NUMBER} .
              
              # 이미지 태그 및 푸시
              docker push \${IMAGE_NAME}:\${BUILD_NUMBER}
              docker tag \${IMAGE_NAME}:\${BUILD_NUMBER} \${IMAGE_NAME}:latest
              docker push \${IMAGE_NAME}:latest
          """
        }
      }
    } catch (Exception e) {
      error "Docker build and push failed: ${e.message}"
    }
  }
}

def deployApplication() {
    script {
        // YAML 파일 읽기
        def deploymentYaml = readFile('k8s/deployment.yaml')
        def serviceYaml = readFile('k8s/svc.yaml')
        
        // 환경변수 치환
        deploymentYaml = deploymentYaml.replaceAll('\\$\\{APP_NAME\\}', env.APP_NAME)
                                      .replaceAll('\\$\\{KUBE_NAMESPACE\\}', env.KUBE_NAMESPACE)
                                      .replaceAll('\\$\\{IMAGE_NAME\\}', env.IMAGE_NAME)
                                      .replaceAll('\\$\\{BUILD_NUMBER\\}', env.BUILD_NUMBER)
        
        serviceYaml = serviceYaml.replaceAll('\\$\\{APP_NAME\\}', env.APP_NAME)
                                .replaceAll('\\$\\{KUBE_NAMESPACE\\}', env.KUBE_NAMESPACE)
        
        // 임시 파일 생성 및 배포
        writeFile file: 'temp-deployment.yaml', text: deploymentYaml
        writeFile file: 'temp-svc.yaml', text: serviceYaml
        
        sh """
            kubectl apply -f temp-deployment.yaml
            kubectl apply -f temp-svc.yaml

            # 배포 상태 확인
            kubectl get pods -n ${env.KUBE_NAMESPACE} -l app=${env.APP_NAME}
        """
    }
}