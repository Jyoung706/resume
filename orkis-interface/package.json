{
  "name": "orkis-interface",
  "version": "2.0.0",
  "description": "ORKIS Interface - 양방향 통신 중심의 통신 계약 타입 정의",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    },
    "./shared": {
      "types": "./lib/shared/index.d.ts",
      "import": "./lib/shared/index.js",
      "require": "./lib/shared/index.js"
    },
    "./shared/*": {
      "types": "./lib/shared/*.d.ts",
      "import": "./lib/shared/*.js",
      "require": "./lib/shared/*.js"
    },
    "./backend": {
      "types": "./lib/backend/index.d.ts",
      "import": "./lib/backend/index.js",
      "require": "./lib/backend/index.js"
    },
    "./backend/*": {
      "types": "./lib/backend/*.d.ts",
      "import": "./lib/backend/*.js",
      "require": "./lib/backend/*.js"
    },
    "./core": {
      "types": "./lib/core/index.d.ts",
      "import": "./lib/core/index.js",
      "require": "./lib/core/index.js"
    },
    "./core/*": {
      "types": "./lib/core/*.d.ts",
      "import": "./lib/core/*.js",
      "require": "./lib/core/*.js"
    },
    "./ai": {
      "types": "./lib/ai/index.d.ts",
      "import": "./lib/ai/index.js",
      "require": "./lib/ai/index.js"
    },
    "./ai/*": {
      "types": "./lib/ai/*.d.ts",
      "import": "./lib/ai/*.js",
      "require": "./lib/ai/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w",
    "clean": "rm -rf lib",
    "prebuild": "npm run clean",
    "dev": "npm run build:watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "lib/**/*",
    "src/**/*",
    "README.md"
  ],
  "keywords": [
    "orkis",
    "interface",
    "typescript",
    "api",
    "definitions",
    "backend",
    "frontend",
    "core",
    "decorators",
    "types"
  ],
  "author": "ORKIS Development Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/orkis-interface.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/orkis-interface/issues"
  },
  "homepage": "https://github.com/your-org/orkis-interface#readme",
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/express-fileupload": "^1.5.1",
    "@types/express-session": "^1.18.2",
    "@types/node": "^20.11.0",
    "express-fileupload": "^1.5.2",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "packageManager": "yarn@4.9.0"
}
