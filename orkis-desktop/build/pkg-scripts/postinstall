#!/bin/bash
# Orkis Desktop - postinstall
# PKG 설치 시 root 권한으로 실행됨
# Podman 바이너리는 앱 리소스에 포함 — 별도 설치 불필요

echo "[Orkis] postinstall: starting setup..."

# 앱 번들 경로 탐색
APP_DIR=""
for DIR in "/Applications/orkis.app" "$HOME/Applications/orkis.app"; do
  if [ -d "$DIR" ]; then
    APP_DIR="$DIR"
    break
  fi
done

if [ -z "$APP_DIR" ]; then
  echo "[Orkis] Error: orkis.app not found"
  exit 0
fi

PODMAN="$APP_DIR/Contents/Resources/podman/bin/podman"

if [ ! -x "$PODMAN" ]; then
  echo "[Orkis] Warning: Podman binary not found at $PODMAN"
  exit 0
fi

echo "[Orkis] Podman: $($PODMAN --version 2>/dev/null || echo 'unknown')"

# root로 실행되므로 실제 로그인 사용자로 machine init
REAL_USER=$(stat -f "%Su" /dev/console)
REAL_HOME=$(eval echo ~"$REAL_USER")
echo "[Orkis] Running Podman machine init as user: $REAL_USER"

# helper 바이너리 경로 설정
PODMAN_BIN_DIR="$APP_DIR/Contents/Resources/podman/bin"
PODMAN_LIB_DIR="$APP_DIR/Contents/Resources/podman/lib"

# containers.conf 생성 (helper_binaries_dir 지정)
DATA_DIR="$REAL_HOME/Library/Application Support/orkis-electron"
CONF_DIR="$DATA_DIR/podman"
sudo -u "$REAL_USER" mkdir -p "$CONF_DIR"
cat > "$CONF_DIR/containers.conf" <<CONF
[engine]
helper_binaries_dir = ["$PODMAN_BIN_DIR"]
CONF
chown "$REAL_USER" "$CONF_DIR/containers.conf"

# 공백 경로 문제를 피하기 위해 env 변수를 개별 export로 설정
export PATH="$PODMAN_BIN_DIR:$PATH"
export DYLD_LIBRARY_PATH="$PODMAN_LIB_DIR"
export CONTAINERS_CONF="$CONF_DIR/containers.conf"

run_as_user() {
  sudo -u "$REAL_USER" \
    PATH="$PATH" \
    DYLD_LIBRARY_PATH="$DYLD_LIBRARY_PATH" \
    CONTAINERS_CONF="$CONTAINERS_CONF" \
    "$@"
}

if ! run_as_user "$PODMAN" machine inspect &>/dev/null 2>&1; then
  echo "[Orkis] Initializing Podman machine..."
  run_as_user "$PODMAN" machine init --cpus 2 --memory 4096
  echo "[Orkis] Podman machine initialized"
else
  echo "[Orkis] Podman machine already exists"
fi

echo "[Orkis] postinstall: setup complete"
