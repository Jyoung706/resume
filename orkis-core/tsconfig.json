{
  "compilerOptions": {
    // ============ 컴파일 대상 ============
    "target": "ES2022",
    "module": "commonjs",

    // ============ 데코레이터 (NestJS/TypeORM 등) ============
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    // ============ 입출력 ============
    "outDir": "./lib",

    // ============ 타입 선언 ============
    "declaration": true,

    // ============ 디버깅 ============
    "sourceMap": true,
    "declarationMap": true,
    "inlineSources": true,

    // ============ 빌드 최적화 ============
    "removeComments": true,
    "skipLibCheck": true,

    // ============ 엄격한 타입 체크 ============
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true
  }
}
