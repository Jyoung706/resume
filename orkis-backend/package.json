{
  "name": "orkis-backend",
  "version": "1.0.0",
  "license": "MIT",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "start": "ts-node -P ./tsconfig.prod.json ./src/main.ts -e dev",
    "start:docker": "ts-node -P ./tsconfig.prod.json ./src/main.ts -e prod",
    "dev": "NODE_ENV=development ts-node -P ./tsconfig.dev.json ./src/main.ts -e dev",
    "dev:debug": "NODE_ENV=development node --inspect=0.0.0.0:9229 -r ts-node/register -r tsconfig-paths/register ./src/main.ts -e dev",
    "dev:simple": "node ./src/start-simple.js",
    "build": "yarn build:interface && yarn build:backend",
    "build:interface": "test -d orkis-interface && (cd orkis-interface && echo 'Building interface...' && yarn install && echo 'Starting tsc build...' && yarn build && echo 'Interface build completed. Checking lib directory...' && ls -la lib/ && echo 'Contents of lib/backend:' && ls -la lib/backend/) || echo 'Interface directory not found, skipping...'",
    "build:interface-test": "test -d orkis-interface && (cd orkis-interface && tsc && tsc-alias -p ./tsconfig.json) || echo 'Interface already built in Docker'",
    "build:backend": "tsc -p ./tsconfig.prod.json && tsc-alias -p ./tsconfig.prod.json",
    "build:desktop": "tsc -p ./tsconfig.desktop.json && tsc-alias -p ./tsconfig.desktop.json",
    "prod": "NODE_ENV=prod node ./lib/src/main.js -e prod",
    "docker:build2": "docker-compose build",
    "docker:build": "docker-compose build --no-cache",
    "docker:run": "docker-compose up -d",
    "docker:logs": "docker-compose logs -f",
    "docker:down": "docker-compose down",
    "docker:dev:build": "cd .. && docker build -t orkis-backend:dev -f orkis-backend/dev.Dockerfile .",
    "docker:dev:run": "docker run -d --name orkis-backend-dev --network orkis-network -p 8080:8080 -e REDIS_HOST=orkis-chat-redis-dev -e REDIS_PORT=6379 orkis-backend:dev",
    "docker:dev:stop": "docker stop orkis-backend-dev && docker rm orkis-backend-dev",
    "docker:dev:logs": "docker logs orkis-backend-dev -f",
    "docker:dev:restart": "yarn docker:dev:stop; yarn docker:dev:build && yarn docker:dev:run",
    "format": "prettier --write src/**/*.{ts,tsx,js,jsx,json}",
    "format:check": "prettier --check src/**/*.{ts,tsx,js,jsx,json}",
    "character:export": "ts-node -r tsconfig-paths/register -P ./tsconfig.dev.json scripts/character/run-export-character.ts",
    "check:sqlvalidation": "ts-node -r tsconfig-paths/register -P ./tsconfig.dev.json scripts/check/run-sql-validation.ts",
    "check:executiontracker": "ts-node -r tsconfig-paths/register -P ./tsconfig.dev.json scripts/check/run-execution-tracker.ts",
    "check:adaptercontract": "ts-node -r tsconfig-paths/register -P ./tsconfig.dev.json scripts/check/run-adapter-contract.ts",
    "pg:setup": "ts-node -r tsconfig-paths/register -P ./tsconfig.dev.json scripts/check/setup-pg-fixture.ts",
    "mysql:setup": "ts-node -r tsconfig-paths/register -P ./tsconfig.dev.json scripts/check/setup-mysql-fixture.ts",
    "mariadb:setup": "ts-node -r tsconfig-paths/register -P ./tsconfig.dev.json scripts/check/setup-mariadb-fixture.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@azure/identity": "^4.5.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@orkis/core": "^1.0.24",
    "bcrypt": "^6.0.0",
    "express-fileupload": "^1.5.2",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.9.1",
    "pg-query-stream": "^4.7.1",
    "uuid": "^11.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express-fileupload": "^1.5.1",
    "@types/express-session": "^1.18.2",
    "@types/fs-extra": "^9.0.13",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.3",
    "@types/pg": "^8.15.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "fs-extra": "^10.1.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.7.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "yarn@4.9.0"
}
