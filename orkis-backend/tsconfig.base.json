{
  "compilerOptions": {
    "target": "ES2022", // interfaceм—җ л§һм¶° мғҒн–Ҙ
    "module": "node16", // нҳ„мһ¬ runtime м„Өм • мң м§Җ
    "outDir": "lib",
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "declaration": false, // runtimeмқҖ false мң м§Җ
    "removeComments": true,
    "paths": {
      "@/*": ["./src/main/*"],
      "@orkis-interface/*": ["./orkis-interface/src/*"]
    }
  }
}
