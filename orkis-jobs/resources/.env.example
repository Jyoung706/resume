# DI System Configuration
ORKIS_DI_MODE=new

# Redis Configuration (Main Redis - 채팅 세션 데이터)
REDIS_HOST=localhost
REDIS_PORT=6380

# Message Redis Configuration (메시지 스트리밍 전용)
REDIS_STAGE_HOST=localhost
REDIS_STAGE_PORT=6381

# Job Configuration
# 체크 주기 (초 단위로 변경)
SESSION_CHECK_INTERVAL_SECONDS=10

# 세션 타임아웃 시간 (분 단위, 기본: 60분)
SESSION_TIMEOUT_MINUTES=60

# 시작 시 즉시 실행 여부
RUN_ON_STARTUP=true

# 데이터 아카이브 설정
# 아카이브 작업 주기 (초 단위, 기본: 10초)
DATA_ARCHIVE_INTERVAL_SECONDS=10

# 아카이브 디렉토리 경로 (기본: 현재 디렉토리의 'archive' 폴더)
DATA_ARCHIVE_DIR_PATH=data-archive

# 시작 시 아카이브 즉시 실행 여부
RUN_ARCHIVE_ON_STARTUP=true

# 환경 설정
NODE_ENV=development

# 서버 포트
PORT=3002

# SCAN + Pipeline 최적화 설정
# SCAN 배치 크기 (키 스캔 시 한 번에 처리할 키 개수)
REDIS_SCAN_BATCH_SIZE=1000

# Pipeline 배치 크기 (한 번에 Pipeline으로 처리할 명령어 개수)
REDIS_PIPELINE_BATCH_SIZE=100

# 삭제 배치 크기 (한 번에 삭제할 키 개수)
REDIS_DELETE_BATCH_SIZE=50

# 동시 세션 처리 개수 (병렬 처리 시 동시 실행할 세션 개수)
REDIS_CONCURRENT_SESSIONS=5

# SCAN + Pipeline 최적화 활성화 (true/false)
ENABLE_REDIS_OPTIMIZATION=false

# 성능 메트릭 로깅 활성화 (true/false)
ENABLE_PERFORMANCE_METRICS=true

# 배치 작업 로깅 활성화 (true/false)
LOG_BATCH_OPERATIONS=true