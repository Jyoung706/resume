{
  "name": "orkis-front",
  "version": "1.0.0",
  "description": "Orkis UI Framework - React + MUI + TypeScript",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "src/main.tsx"
  ],
  "scripts": {
    "dev": "vite",
    "dev:ag": "cross-env VITE_ENABLE_AGENTATION=true vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5173",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docker:build": "docker-compose build --no-cache",
    "docker:run": "docker-compose up -d",
    "docker:logs": "docker-compose logs -f",
    "docker:down": "docker-compose down",
    "docker:network": "docker network create orkis-network",
    "docker:dev:build": "cd .. && docker build -t orkis-front:dev -f orkis-front/Dockerfile.dev .",
    "docker:dev:run": "docker run -d --name orkis-front-dev --network orkis-network -p 5173:5173 -e VITE_API_URL=http://orkis-backend-dev:8080 orkis-front:dev",
    "docker:dev:stop": "docker stop orkis-front-dev && docker rm orkis-front-dev",
    "docker:dev:logs": "docker logs orkis-front-dev -f",
    "docker:dev:restart": "yarn docker:dev:stop; yarn docker:dev:build && yarn docker:dev:run"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/nanum-myeongjo": "^5.2.11",
    "@fontsource/noto-sans": "^5.2.10",
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@fontsource/roboto": "^5.2.10",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.8",
    "agentation": "^2.2.1",
    "clsx": "^2.1.1",
    "dockview-react": "^5.2.0",
    "dompurify": "^3.3.3",
    "html-react-parser": "^6.0.1",
    "nanoid": "^5.1.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.1",
    "react-virtuoso": "^4.18.7",
    "remark-gfm": "^4",
    "sql-formatter": "^15.7.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sass-embedded": "^1.97.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "packageManager": "yarn@4.9.4"
}
